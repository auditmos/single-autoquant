# --- API Keys ---
ALPHA_VANTAGE_API_KEY=          # Required. ETF barometers, macro, sentiment. Premium for full history.
FRED_API_KEY=                   # Optional. Reserved for future macro indicators.
BITCOIN_DATA_API_KEY=           # Optional. Reserved for future BTC on-chain data.

# --- Assets ---
ASSETS=BTC,ETH,XMR,SOL,TAO     # Comma-separated crypto tickers to trade. Each gets /USDT pair.
SENTIMENT_ASSETS=               # Override sentiment tickers. Empty = same as ASSETS. Example: BTC,ETH

# --- Backtest periods (YYYY-MM-DD) ---
TRAIN_START=2023-03-17          # Training period start. Also used as AV sentiment time_from.
TRAIN_END=2025-03-17            # Training period end = validation start.
VAL_START=2025-03-17            # Validation period start.
VAL_END=2026-03-17              # Validation period end.

# --- Notifications ---
NOTIFY_ENDPOINT=                # Webhook URL for JSON notifications. Empty = disabled.
NOTIFY_BEARER=                  # Bearer token for webhook auth. Empty = no auth header.

# --- Claude agent ---
CLAUDE_MODEL=                   # Model override. Empty = default. Example: claude-sonnet-4-5
CLAUDE_TIMEOUT=3600             # Max seconds per Claude iteration. Default: 3600 (60 min).

# --- GPU ---
GPU_ID=0                        # NVIDIA GPU device ID. For multi-GPU: 0, 1, 2, etc.
